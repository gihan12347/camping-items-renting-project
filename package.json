{
  "name": "nature-nest",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=18.17.0"
  },
  "scripts": {
    "clean": "node -e \"const fs=require('fs');const rm=(p)=>{try{fs.rmSync(p,{recursive:true,force:true})}catch(e){}};rm('.next');rm('node_modules/.cache');\"",
    "dev": "next dev",
    "dev:fresh": "npm run clean && next dev",
    "build": "next build",
    "start": "next start"
  },
  "dependencies": {
    "@namnguyenthanhwork/react-snowfall-effect": "^1.0.3",
    "framer-motion": "^12.23.24",
    "lucide-react": "^0.545.0",
    "next": "^14.2.35",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-snowfall": "^2.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
